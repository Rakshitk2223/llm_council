# =============================================================================
# AXIS COUNCIL - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# LLM PROVIDER CONFIGURATION (Provider-Agnostic)
# -----------------------------------------------------------------------------
# This configuration works with any OpenAI-compatible API:
# - OpenAI: https://api.openai.com/v1
# - Azure OpenAI: https://your-resource.openai.azure.com/v1
# - LM Studio (local): http://localhost:1234/v1
# - Ollama: http://localhost:11434/v1
# - Together.ai: https://api.together.xyz/v1
# - Groq: https://api.groq.com/openai/v1
# - Any OpenAI-compatible endpoint

# Base URL for the LLM API (include /v1 suffix for OpenAI-compatible APIs)
# Examples:
#   OpenAI:       https://api.openai.com/v1
#   Azure:        https://your-resource.openai.azure.com/v1
#   LM Studio:    http://localhost:1234/v1
#   Ollama:       http://localhost:11434/v1
LLM_BASE_URL=http://localhost:1234/v1

# API Key (leave as "not-needed" for local LLMs like LM Studio/Ollama)
LLM_API_KEY=not-needed

# For Azure OpenAI only: API version (ignored by other providers)
AZURE_API_VERSION=2024-02-15-preview

# -----------------------------------------------------------------------------
# JWT AUTHENTICATION
# -----------------------------------------------------------------------------
# Must match the secret used by the main site's authentication system
# The main dashboard team should provide this value

# Secret key for JWT token validation
JWT_SECRET=your-jwt-secret-here

# Algorithm used for JWT signing (usually HS256)
JWT_ALGORITHM=HS256

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
# Number of queries allowed per user per day
# Adjust based on your cost tolerance and user expectations

RATE_LIMIT_PER_DAY=20

# -----------------------------------------------------------------------------
# CORS CONFIGURATION
# -----------------------------------------------------------------------------
# Frontend URL for CORS (Cross-Origin Resource Sharing)
# Update this to match your frontend deployment URL

# For local development:
FRONTEND_URL=http://localhost:5173

# For production, use your actual frontend URL:
# FRONTEND_URL=https://your-site.com
