# Azure OpenAI (Primary Provider)
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Azure Foundry (Secondary Provider - optional)
# If Azure OpenAI is empty, this becomes the primary
AZURE_FOUNDRY_API_KEY=
AZURE_FOUNDRY_ENDPOINT=

# Third-Party Providers (optional)
# For Claude models
ANTHROPIC_API_KEY=
# For Grok models
XAI_API_KEY=

# JWT Authentication (disabled by default)
JWT_SECRET=dev-secret-change-in-production
JWT_ALGORITHM=HS256

# Rate Limiting (disabled/high limit by default)
RATE_LIMIT_PER_DAY=1000

# CORS (allow all origins)
FRONTEND_URL=*
